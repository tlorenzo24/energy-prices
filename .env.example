# ─────────────────────────────────────────────────────────────────────────
# energy-prices configuration. Copy to ".env" and fill in. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────────────

# --- Database -------------------------------------------------------------
# Local dev (zero-setup, default): SQLite file under ./data
ENERGY_DATABASE_URL=sqlite:///./data/energy_prices.db
# Production (Docker compose Postgres + TimescaleDB):
# ENERGY_DATABASE_URL=postgresql+psycopg2://energy:energy@localhost:5432/energy

# --- ENTSO-E Transparency Platform (PRIMARY electricity source, FREE) -----
# Get a token: register at https://transparency.entsoe.eu then email
# transparency@entsoe.eu (subject "RESTful API access"). ~3 working days.
ENERGY_ENTSOE_API_TOKEN=

# --- GME official REST API (AUTHORITATIVE: PUN Index, intraday, gas) -------
# Credentials issued by GME after PEC registration. You already have operator
# access — put the API username/password here.
ENERGY_GME_API_BASE_URL=https://api.mercatoelettrico.org/request
ENERGY_GME_API_USERNAME=
ENERGY_GME_API_PASSWORD=

# --- Gas fundamentals (FREE keys, optional but recommended) ---------------
# GIE AGSI+ gas storage: free key at https://agsi.gie.eu/account
ENERGY_AGSI_API_KEY=
# EIA (US Henry Hub, global context): instant free key https://www.eia.gov/opendata/
ENERGY_EIA_API_KEY=

# --- Scheduler (daily ingest + forecast loop) -----------------------------
# GME publishes the MGP results ~13:00–13:30 CET; the job runs a little after.
ENERGY_SCHEDULER_HOUR=13
ENERGY_SCHEDULER_MINUTE=30
ENERGY_SCHEDULER_RUN_ON_START=true
ENERGY_SCHEDULER_MISFIRE_GRACE=3600

# --- Alert delivery (webhook + email) -------------------------------------
# n8n webhook (cloud or self-hosted): triggered price alerts are POSTed here as
# JSON; n8n then fans out to email/Slack/Telegram. Leave empty = stub (logs the
# payload only). Build the n8n workflow once the webhook URL is known.
ENERGY_ALERT_WEBHOOK_URL=
ENERGY_ALERT_WEBHOOK_TOKEN=
# Direct SMTP email (alternative/in addition to the webhook). Leave SMTP_HOST
# empty to disable. ENERGY_ALERT_EMAIL_TO is comma-separated.
ENERGY_ALERT_EMAIL_TO=
ENERGY_SMTP_HOST=
ENERGY_SMTP_PORT=587
ENERGY_SMTP_USER=
ENERGY_SMTP_PASSWORD=
ENERGY_SMTP_FROM=
ENERGY_SMTP_STARTTLS=true

# --- Dashboard auth (shared deployment) -----------------------------------
# Optional shared-secret gate for the Streamlit dashboard. Use together with a
# VPN (Tailscale) for internal sharing. Empty = no gate.
ENERGY_DASHBOARD_PASSWORD=

# --- Postgres credentials (docker-compose) --------------------------------
# Used by docker-compose for the TimescaleDB container. Change before sharing.
POSTGRES_USER=energy
POSTGRES_PASSWORD=energy
POSTGRES_DB=energy

# --- Behaviour ------------------------------------------------------------
ENERGY_TIMEZONE=Europe/Rome
# DEMO_MODE=true generates realistic synthetic data so the dashboard works
# with no credentials. Set to false once real ingestion is configured.
ENERGY_DEMO_MODE=true
ENERGY_LOG_LEVEL=INFO
# Open-Meteo weather ingestion (temp / HDD / CDD drivers). OFF by default: the
# Open-Meteo FREE tier is NON-COMMERCIAL use only. Enable only under a paid or
# self-hosted Open-Meteo plan for commercial (e.g. trading) use.
ENERGY_ENABLE_WEATHER=false
